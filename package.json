{
  "name": "hospital-messenger-v2",
  "version": "2.0.0",
  "description": "Hospital Messenger with local IndexedDB - APK Ready",
  "main": "index.tsx",
  "scripts": {
    "dev": "react-scripts start",
    "start": "react-scripts start",
    "build": "react-scripts build",
    "build:apk": "npm run build && npm run cap:copy && npm run apk:debug",
    "cap:init": "npx cap init",
    "cap:add": "npx cap add android",
    "cap:build": "npx cap build android",
    "cap:copy": "npx cap copy android",
    "cap:sync": "npx cap sync android",
    "apk:debug": "cd android && ./gradlew clean assembleDebug"
  },
  "dependencies": {
    "@capacitor-firebase/messaging": "^8.0.1",
    "@capacitor/android": "^8.0.0",
    "@capacitor/app": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/device": "^8.0.0",
    "@capacitor/push-notifications": "^8.0.0",
    "@capacitor/splash-screen": "^8.0.0",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "date-fns": "^4.1.0",
    "firebase": "^12.8.0",
    "idb": "8.0.0",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-scripts": "5.0.1",
    "typescript": "^4.9.5"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.0.0",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "vite": "^7.3.1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
